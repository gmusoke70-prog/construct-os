{
  "name": "construct-os",
  "version": "1.0.0",
  "description": "Enterprise construction OS — 9-portal professional platform",
  "private": true,
  "workspaces": [
    "packages/shared",
    "portals/qs",
    "portals/qs/frontend",
    "portals/pm",
    "portals/pm/frontend",
    "portals/architect",
    "portals/architect/frontend",
    "portals/structural",
    "portals/structural/frontend",
    "portals/procurement",
    "portals/procurement/frontend",
    "portals/hr",
    "portals/hr/frontend",
    "portals/finance",
    "portals/finance/frontend",
    "portals/admin",
    "portals/admin/frontend",
    "portals/client",
    "portals/client/frontend",
    "services/api-gateway",
    "services/auth"
  ],
  "scripts": {
    "dev":         "concurrently -n auth,gateway,qs,pm,arch,struct,proc,hr,fin,admin,client -c white,blue,green,cyan,magenta,yellow,red,pink,lime,orange,gray \"npm run dev:auth\" \"npm run dev:gateway\" \"npm run dev:qs\" \"npm run dev:pm\" \"npm run dev:architect\" \"npm run dev:structural\" \"npm run dev:procurement\" \"npm run dev:hr\" \"npm run dev:finance\" \"npm run dev:admin\" \"npm run dev:client\"",
    "dev:ui":      "concurrently -n qs-ui,pm-ui,arch-ui,struct-ui,proc-ui,hr-ui,fin-ui,admin-ui,client-ui -c green,cyan,magenta,yellow,red,pink,lime,orange,gray \"npm run dev:ui:qs\" \"npm run dev:ui:pm\" \"npm run dev:ui:architect\" \"npm run dev:ui:structural\" \"npm run dev:ui:procurement\" \"npm run dev:ui:hr\" \"npm run dev:ui:finance\" \"npm run dev:ui:admin\" \"npm run dev:ui:client\"",
    "dev:ui:qs":         "npm run dev --workspace=portals/qs/frontend",
    "dev:ui:pm":         "npm run dev --workspace=portals/pm/frontend",
    "dev:ui:architect":  "npm run dev --workspace=portals/architect/frontend",
    "dev:ui:structural": "npm run dev --workspace=portals/structural/frontend",
    "dev:ui:procurement":"npm run dev --workspace=portals/procurement/frontend",
    "dev:ui:hr":         "npm run dev --workspace=portals/hr/frontend",
    "dev:ui:finance":    "npm run dev --workspace=portals/finance/frontend",
    "dev:ui:admin":      "npm run dev --workspace=portals/admin/frontend",
    "dev:ui:client":     "npm run dev --workspace=portals/client/frontend",
    "dev:gateway":     "node services/api-gateway/src/index.js",
    "dev:auth":        "node services/auth/src/index.js",
    "dev:qs":          "node portals/qs/backend/index.js",
    "dev:pm":          "node portals/pm/backend/index.js",
    "dev:architect":   "node portals/architect/backend/index.js",
    "dev:structural":  "node portals/structural/backend/index.js",
    "dev:procurement": "node portals/procurement/backend/index.js",
    "dev:hr":          "node portals/hr/backend/index.js",
    "dev:finance":     "node portals/finance/backend/index.js",
    "dev:admin":       "node portals/admin/backend/index.js",
    "dev:client":      "node portals/client/backend/index.js",
    "db:push":         "cd packages/shared && npx prisma db push",
    "db:migrate":      "cd packages/shared && npx prisma migrate dev",
    "db:studio":       "cd packages/shared && npx prisma studio",
    "db:seed":         "node packages/shared/prisma/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon":      "^3.1.0"
  }
}
