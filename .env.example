# ─── Construct-OS — Environment variables ─────────────────────────────────────
# Copy to .env and fill in real values before starting.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=constructos
DATABASE_URL=postgresql://postgres:change_me_in_production@localhost:5432/constructos

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_hex_secret_here
JWT_EXPIRES_IN=8h

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis (session cache, rate-limit state) ────────────────────────────────────
REDIS_URL=redis://:redispass@localhost:6379
REDIS_PASSWORD=redispass

# ── Object storage (MinIO / S3-compatible) ────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=construct-os
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# For production — replace MinIO with real S3:
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=AKIA...
# MINIO_SECRET_KEY=...
# MINIO_BUCKET=my-construct-os-bucket

# ── SMTP (invite emails) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@construct-os.io

# ── Application ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ── Service ports ─────────────────────────────────────────────────────────────
# Only needed if overriding defaults (used by api-gateway in docker-compose)
GATEWAY_PORT=3000
QS_PORT=3005
ARCHITECT_PORT=3006
STRUCTURAL_PORT=3007
PROCUREMENT_PORT=3008
HR_PORT=3009
FINANCE_PORT=3010
ADMIN_PORT=3011
PM_PORT=3012
CLIENT_PORT=3013

# ── Service URLs (api-gateway uses these to proxy; defaults work for docker) ──
AUTH_SERVICE_URL=http://localhost:3001
QS_URL=http://localhost:3005
ARCHITECT_URL=http://localhost:3006
STRUCTURAL_URL=http://localhost:3007
PROCUREMENT_URL=http://localhost:3008
HR_URL=http://localhost:3009
FINANCE_URL=http://localhost:3010
ADMIN_URL=http://localhost:3011
PM_URL=http://localhost:3012
CLIENT_URL=http://localhost:3013
